<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      const stored = localStorage.getItem('theme')
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
      const isDark = stored === 'dark' || (!stored && prefersDark)
      if (isDark) {
        document.documentElement.classList.add('dark')
        document.documentElement.style.backgroundColor = 'black'
      }
    </script>
    <script is:inline src={`${import.meta.env.BASE_URL}coi-serviceworker.min.js`}></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Splicer</title>
  </head>
  <body class="h-screen bg-linear-to-b from-slate-100 via-slate-200 to-slate-300 text-slate-900 dark:from-slate-950 dark:via-slate-950 dark:to-slate-900 dark:text-slate-50">
    <slot />
  </body>
</html>
