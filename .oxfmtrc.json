{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortTailwindcss": {
    "functions": ["tw", "clsx", "cva"]
  },
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "ignorePatterns": ["**/public/**", "**/dist/**", "**/node_modules/**"],
  "jsxSingleQuote": false,
  "semi": false,
  "singleQuote": true,
  "sortImports": true,
  "sortPackageJson": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false
}
